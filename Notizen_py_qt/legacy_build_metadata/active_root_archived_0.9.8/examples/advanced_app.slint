import { Button, CheckBox, LineEdit, VerticalBox } from "std-widgets.slint";

export enum Theme { Light, Dark = 2 }

export struct TodoItem {
    title: string,
    done: bool,
}

export global AppState {
    in-out property <bool> busy: false;
    callback save-requested(string);
}

export component MainWindow inherits Window {
    in-out property <string> title-text <=> titleField.text;
    in property <[TodoItem]> rows;
    width: 900px;
    height: 600px;

    VerticalBox {
        titleField := LineEdit {
            text <=> root.title-text;
            placeholder-text: @tr("Titel");
        }
        Button { text: @tr("Speichern"); clicked => { AppState.save-requested(root.title-text); } }
        for row[i] in rows: CheckBox { text: row.title; checked: row.done; }
        animate opacity { duration: 250ms; }
    }
}
