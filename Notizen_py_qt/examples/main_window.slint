import { Button, VerticalBox, HorizontalBox, LineEdit } from "std-widgets.slint";

export component MainWindow inherits Window {
    in property <string> title-text: "Notizen";
    in-out property <string> source-code: "";
    out property <string> output-code: "";
    callback transpile-requested(string);

    width: 1100px;
    height: 720px;
    background: #202124;

    VerticalBox {
        spacing: 8px;
        Text { text: root.title-text; color: #ffffff; font-size: 24px; }
        HorizontalBox {
            Button { text: "Transpilieren"; clicked => { root.transpile-requested(root.source-code); } }
            LineEdit { placeholder-text: "Datei oder Code"; text: root.source-code; }
        }
        for row[i] in rows: Text { text: row.title; }
        if root.output-code != "": Text { text: root.output-code; }
    }
}
