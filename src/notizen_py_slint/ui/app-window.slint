import { Button, CheckBox, LineEdit, TextEdit, ListView } from "std-widgets.slint";

component ContextAction inherits Rectangle {
    in property <string> label;
    callback activated();
    height: 26px;
    background: pointer.has-hover ? #eaf2ff : #ffffff;
    Text {
        x: 8px;
        width: parent.width - 16px;
        height: parent.height;
        text: root.label;
        vertical-alignment: center;
        overflow: elide;
    }
    pointer := TouchArea {
        width: parent.width;
        height: parent.height;
        clicked => { root.activated(); }
    }
}

component ContextSeparator inherits Rectangle {
    height: 1px;
    background: #dddddd;
}


export struct NoteRow {
    label: string,
    selected: bool,
}

export component AppWindow inherits Window {
    width: 1240px;
    height: 900px;
    title: root.window-title;

    in-out property <string> window-title: "Notizen Py Slint";
    in-out property <[NoteRow]> rows;
    in-out property <int> selected-index: -1;
    in-out property <string> editor-text;
    in-out property <string> note-title;
    in-out property <string> search-text;
    in-out property <bool> search-case-sensitive: false;
    in-out property <bool> search-whole-words: false;
    in-out property <bool> search-current-subtree: false;
    in-out property <string> status-text: "Bereit";
    in-out property <string> meta-text: "";
    in-out property <string> mode-label: "Modus: Text";
    in-out property <bool> dirty: false;
    property <bool> tree-menu-open: false;
    property <bool> editor-menu-open: false;
    property <int> context-row: -1;

    callback new-document();
    callback open-document();
    callback open-recent-document();
    callback open-remote-document();
    callback save-document();
    callback save-document-as();
    callback save-remote-document();
    callback set-password();
    callback export-text();
    callback export-rtf();
    callback export-html();
    callback export-markdown();
    callback export-json();
    callback export-alx();
    callback export-opml();
    callback export-notes-doc();
    callback export-subtree-text();
    callback export-subtree-rtf();
    callback export-note-rtf();
    callback export-sticky-html();
    callback extract-images();
    callback import-text();
    callback import-rtf();
    callback import-json();
    callback import-opml();
    callback insert-image();
    callback append-date();
    callback append-bullet();
    callback add-child();
    callback add-sibling();
    callback delete-note();
    callback duplicate-note();
    callback combine-subtree();
    callback copy-node();
    callback cut-node();
    callback paste-node();
    callback move-up();
    callback move-down();
    callback indent-note();
    callback outdent-note();
    callback toggle-expand();
    callback expand-all();
    callback collapse-all();
    callback select-row(int);
    callback rename-row(int);
    callback rename-current(string);
    callback editor-changed(string);
    callback search-next(string);
    callback search-all(string);
    callback replace-text(string);
    callback toggle-raw-rtf();
    callback toggle-sticky();
    callback set-sticky-geometry();
    callback autosize-sticky();
    callback set-colors();
    callback apply-light-color();
    callback clear-colors();
    callback format-note();
    callback apply-bold();
    callback apply-italic();
    callback apply-underline();
    callback apply-strike();
    callback apply-regular();
    callback increase-font-size();
    callback decrease-font-size();
    callback open-settings();
    callback import-legacy-config();
    callback open-alarm();
    callback show-next-alarm();
    callback show-stats();
    callback show-backups();
    callback show-about();
    callback show-shortcuts();
    callback show-context-menus();
    callback show-fonts();
    callback show-compat-report();
    callback show-default-paths();
    callback show-password-info();
    callback repair-document();
    callback show-toolstrips();

    VerticalLayout {
        padding: 8px;
        spacing: 8px;

        Rectangle {
            height: 232px;
            background: #f6f6f6;
            border-color: #dadada;
            border-width: 1px;
            VerticalLayout {
                padding: 6px;
                spacing: 5px;
                HorizontalLayout {
                    spacing: 6px;
                    Text { text: "Datei"; font-weight: 700; vertical-alignment: center; }
                    Button { text: "Neu"; clicked => { root.new-document(); } }
                    Button { text: "Öffnen"; clicked => { root.open-document(); } }
                    Button { text: "Zuletzt"; clicked => { root.open-recent-document(); } }
                    Button { text: "FTP öffnen"; clicked => { root.open-remote-document(); } }
                    Button { text: "Speichern"; clicked => { root.save-document(); } }
                    Button { text: "Speichern unter"; clicked => { root.save-document-as(); } }
                    Button { text: "FTP speichern"; clicked => { root.save-remote-document(); } }
                    Button { text: "Passwort"; clicked => { root.set-password(); } }
                    Rectangle { horizontal-stretch: 1; }
                    Text { text: root.dirty ? "● geändert" : "gespeichert"; vertical-alignment: center; }
                }
                HorizontalLayout {
                    spacing: 6px;
                    Text { text: "Export"; font-weight: 700; vertical-alignment: center; }
                    Button { text: "TXT"; clicked => { root.export-text(); } }
                    Button { text: "RTF"; clicked => { root.export-rtf(); } }
                    Button { text: "HTML"; clicked => { root.export-html(); } }
                    Button { text: "MD"; clicked => { root.export-markdown(); } }
                    Button { text: "JSON"; clicked => { root.export-json(); } }
                    Button { text: "Teil ALX"; clicked => { root.export-alx(); } }
                    Button { text: "OPML"; clicked => { root.export-opml(); } }
                    Button { text: "NotesDoc"; clicked => { root.export-notes-doc(); } }
                    Button { text: "Teil TXT"; clicked => { root.export-subtree-text(); } }
                    Button { text: "Teil RTF"; clicked => { root.export-subtree-rtf(); } }
                    Button { text: "Notiz-RTF"; clicked => { root.export-note-rtf(); } }
                    Button { text: "Sticky HTML"; clicked => { root.export-sticky-html(); } }
                    Rectangle { horizontal-stretch: 1; }
                }
                HorizontalLayout {
                    spacing: 6px;
                    Text { text: "Import/Baum"; font-weight: 700; vertical-alignment: center; }
                    Button { text: "Import TXT"; clicked => { root.import-text(); } }
                    Button { text: "Import RTF"; clicked => { root.import-rtf(); } }
                    Button { text: "Import JSON"; clicked => { root.import-json(); } }
                    Button { text: "Import OPML"; clicked => { root.import-opml(); } }
                    Button { text: "Bild+"; clicked => { root.insert-image(); } }
                    Rectangle { width: 1px; background: #cccccc; }
                    Button { text: "+ Kind"; clicked => { root.add-child(); } }
                    Button { text: "+ Daneben"; clicked => { root.add-sibling(); } }
                    Button { text: "Dupl."; clicked => { root.duplicate-note(); } }
                    Button { text: "Zusammenf."; clicked => { root.combine-subtree(); } }
                    Button { text: "Löschen"; clicked => { root.delete-note(); } }
                    Button { text: "Kopieren"; clicked => { root.copy-node(); } }
                    Button { text: "Ausschneiden"; clicked => { root.cut-node(); } }
                    Button { text: "Einfügen"; clicked => { root.paste-node(); } }
                    Rectangle { horizontal-stretch: 1; }
                }
                HorizontalLayout {
                    spacing: 6px;
                    Text { text: "Ordnen/RTF"; font-weight: 700; vertical-alignment: center; }
                    Button { text: "↑"; clicked => { root.move-up(); } }
                    Button { text: "↓"; clicked => { root.move-down(); } }
                    Button { text: "Einr."; clicked => { root.indent-note(); } }
                    Button { text: "Ausr."; clicked => { root.outdent-note(); } }
                    Button { text: "Auf/Zu"; clicked => { root.toggle-expand(); } }
                    Button { text: "Alle auf"; clicked => { root.expand-all(); } }
                    Button { text: "Alle zu"; clicked => { root.collapse-all(); } }
                    Rectangle { width: 1px; background: #cccccc; }
                    Button { text: "Format"; clicked => { root.format-note(); } }
                    Button { text: "B"; clicked => { root.apply-bold(); } }
                    Button { text: "I"; clicked => { root.apply-italic(); } }
                    Button { text: "U"; clicked => { root.apply-underline(); } }
                    Button { text: "S"; clicked => { root.apply-strike(); } }
                    Button { text: "Normal"; clicked => { root.apply-regular(); } }
                    Button { text: "A+"; clicked => { root.increase-font-size(); } }
                    Button { text: "A-"; clicked => { root.decrease-font-size(); } }
                    Button { text: "Datum+"; clicked => { root.append-date(); } }
                    Button { text: "•+"; clicked => { root.append-bullet(); } }
                    Button { text: "Bilder"; clicked => { root.extract-images(); } }
                    Rectangle { horizontal-stretch: 1; }
                }
                HorizontalLayout {
                    spacing: 6px;
                    Text { text: "Sticky/Farbe"; font-weight: 700; vertical-alignment: center; }
                    Button { text: "Sticky"; clicked => { root.toggle-sticky(); } }
                    Button { text: "Geom."; clicked => { root.set-sticky-geometry(); } }
                    Button { text: "Auto-Größe"; clicked => { root.autosize-sticky(); } }
                    Button { text: "Farben"; clicked => { root.set-colors(); } }
                    Button { text: "Hell"; clicked => { root.apply-light-color(); } }
                    Button { text: "Farbe weg"; clicked => { root.clear-colors(); } }
                    Rectangle { width: 1px; background: #cccccc; }
                    Button { text: "Stats"; clicked => { root.show-stats(); } }
                    Button { text: "Backups"; clicked => { root.show-backups(); } }
                    Rectangle { horizontal-stretch: 1; }
                    Text { text: "Kontextmenüs: Rechtsklick im Baum oder Editor"; vertical-alignment: center; color: #666666; }
                }
                HorizontalLayout {
                    spacing: 6px;
                    Text { text: "Info/Extras"; font-weight: 700; vertical-alignment: center; }
                    Button { text: "Info"; clicked => { root.show-about(); } }
                    Button { text: "Tasten"; clicked => { root.show-shortcuts(); } }
                    Button { text: "Kontext"; clicked => { root.show-context-menus(); } }
                    Button { text: "Fonts"; clicked => { root.show-fonts(); } }
                    Button { text: "Compat"; clicked => { root.show-compat-report(); } }
                    Button { text: "Pfade"; clicked => { root.show-default-paths(); } }
                    Button { text: "PwInfo"; clicked => { root.show-password-info(); } }
                    Button { text: "Reparieren"; clicked => { root.repair-document(); } }
                    Button { text: "ToolStrips"; clicked => { root.show-toolstrips(); } }
                    Button { text: "Einstellungen"; clicked => { root.open-settings(); } }
                    Button { text: "Wecker"; clicked => { root.open-alarm(); } }
                    Button { text: "Nächster"; clicked => { root.show-next-alarm(); } }
                    Button { text: "Alt-Config"; clicked => { root.import-legacy-config(); } }
                    Rectangle { horizontal-stretch: 1; }
                }
            }
        }

        HorizontalLayout {
            spacing: 8px;
            Rectangle {
                width: 350px;
                background: #ffffff;
                border-color: #d0d0d0;
                border-width: 1px;
                VerticalLayout {
                    padding: 6px;
                    spacing: 6px;
                    Text { text: "Baum"; font-weight: 700; }
                    HorizontalLayout {
                        spacing: 4px;
                        LineEdit {
                            text <=> root.search-text;
                            placeholder-text: "Suchen";
                        }
                        Button { text: "Weiter"; clicked => { root.search-next(root.search-text); } }
                        Button { text: "Alle"; clicked => { root.search-all(root.search-text); } }
                        Button { text: "Ersetzen"; clicked => { root.replace-text(root.search-text); } }
                    }
                    HorizontalLayout {
                        spacing: 4px;
                        CheckBox { text: "Aa"; checked <=> root.search-case-sensitive; }
                        CheckBox { text: "Wort"; checked <=> root.search-whole-words; }
                        CheckBox { text: "Teilbaum"; checked <=> root.search-current-subtree; }
                    }
                    ListView {
                        for row[i] in root.rows: Rectangle {
                            width: parent.width;
                            height: 30px;
                            background: row.selected ? #dbeafe : #ffffff;
                            border-color: row.selected ? #93c5fd : #ffffff;
                            border-width: 1px;
                            Text {
                                x: 6px;
                                y: 0px;
                                width: parent.width - 12px;
                                height: parent.height;
                                text: row.label;
                                vertical-alignment: center;
                                overflow: elide;
                            }
                            row-touch := TouchArea {
                                width: parent.width;
                                height: parent.height;
                                clicked => {
                                    root.tree-menu-open = false;
                                    root.editor-menu-open = false;
                                    root.select-row(i);
                                }
                                pointer-event(event) => {
                                    if event.kind == PointerEventKind.up && event.button == PointerEventButton.right {
                                        root.context-row = i;
                                        root.select-row(i);
                                        root.editor-menu-open = false;
                                        root.tree-menu-open = true;
                                    }
                                }
                            }
                        }
                    }
                }
                if root.tree-menu-open : Rectangle {
                    x: 70px;
                    y: 112px;
                    width: 272px;
                    height: 448px;
                    background: #ffffff;
                    border-color: #64748b;
                    border-width: 1px;
                    VerticalLayout {
                        padding: 4px;
                        spacing: 1px;
                        ContextAction { label: "Neu darunter"; activated => { root.select-row(root.context-row); root.tree-menu-open = false; root.add-child(); } }
                        ContextAction { label: "Neu daneben"; activated => { root.select-row(root.context-row); root.tree-menu-open = false; root.add-sibling(); } }
                        ContextAction { label: "Umbenennen"; activated => { root.tree-menu-open = false; root.rename-row(root.context-row); } }
                        ContextSeparator { }
                        ContextAction { label: "Kopieren"; activated => { root.select-row(root.context-row); root.tree-menu-open = false; root.copy-node(); } }
                        ContextAction { label: "Ausschneiden"; activated => { root.select-row(root.context-row); root.tree-menu-open = false; root.cut-node(); } }
                        ContextAction { label: "Einfügen danach"; activated => { root.select-row(root.context-row); root.tree-menu-open = false; root.paste-node(); } }
                        ContextAction { label: "Duplizieren"; activated => { root.select-row(root.context-row); root.tree-menu-open = false; root.duplicate-note(); } }
                        ContextSeparator { }
                        ContextAction { label: "Löschen"; activated => { root.select-row(root.context-row); root.tree-menu-open = false; root.delete-note(); } }
                        ContextAction { label: "Auf/Zuklappen"; activated => { root.select-row(root.context-row); root.tree-menu-open = false; root.toggle-expand(); } }
                        ContextAction { label: "Nach oben"; activated => { root.select-row(root.context-row); root.tree-menu-open = false; root.move-up(); } }
                        ContextAction { label: "Nach unten"; activated => { root.select-row(root.context-row); root.tree-menu-open = false; root.move-down(); } }
                        ContextAction { label: "Einrücken"; activated => { root.select-row(root.context-row); root.tree-menu-open = false; root.indent-note(); } }
                        ContextAction { label: "Ausrücken"; activated => { root.select-row(root.context-row); root.tree-menu-open = false; root.outdent-note(); } }
                        ContextSeparator { }
                        ContextAction { label: "Notiz als RTF speichern"; activated => { root.select-row(root.context-row); root.tree-menu-open = false; root.export-note-rtf(); } }
                        ContextAction { label: "Desktop-Notiz / Sticky"; activated => { root.select-row(root.context-row); root.tree-menu-open = false; root.toggle-sticky(); } }
                        ContextAction { label: "Hintergrund-/Schriftfarbe"; activated => { root.select-row(root.context-row); root.tree-menu-open = false; root.set-colors(); } }
                        ContextAction { label: "Schließen"; activated => { root.tree-menu-open = false; } }
                    }
                }
            }

            Rectangle {
                background: #ffffff;
                border-color: #d0d0d0;
                border-width: 1px;
                VerticalLayout {
                    padding: 8px;
                    spacing: 8px;
                    HorizontalLayout {
                        spacing: 6px;
                        Text { text: "Titel:"; vertical-alignment: center; }
                        LineEdit { text <=> root.note-title; }
                        Button { text: "Umbenennen"; clicked => { root.rename-current(root.note-title); } }
                        Rectangle { width: 1px; background: #cccccc; }
                        Text { text: root.mode-label; vertical-alignment: center; }
                        Button { text: "RTF/Text"; clicked => { root.toggle-raw-rtf(); } }
                        Button { text: "Bild+"; clicked => { root.insert-image(); } }
                        Button { text: "Datum+"; clicked => { root.append-date(); } }
                        Button { text: "•+"; clicked => { root.append-bullet(); } }
                        Button { text: "RTF Kontext"; clicked => { root.tree-menu-open = false; root.editor-menu-open = !root.editor-menu-open; } }
                        Rectangle { horizontal-stretch: 1; }
                        Text { text: "Kontext über RTF-Kontext oder den Knopf ☰ im Textfeld"; vertical-alignment: center; color: #666666; }
                    }
                    editor-area := Rectangle {
                        vertical-stretch: 1;
                        background: #ffffff;
                        editor := TextEdit {
                            width: parent.width - 36px;
                            height: parent.height;
                            text <=> root.editor-text;
                            wrap: word-wrap;
                            edited(text) => { root.editor-changed(text); }
                        }
                        Rectangle {
                            x: parent.width - 34px;
                            y: 0px;
                            width: 34px;
                            height: parent.height;
                            background: #f8fafc;
                            border-color: #cbd5e1;
                            border-width: 1px;
                            Text {
                                y: 6px;
                                width: parent.width;
                                height: 24px;
                                text: "☰";
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }
                            Text {
                                y: 36px;
                                width: parent.width;
                                height: parent.height - 42px;
                                text: "RTF\nMenü";
                                horizontal-alignment: center;
                                vertical-alignment: center;
                                color: #64748b;
                            }
                            menu-handle := TouchArea {
                                width: parent.width;
                                height: parent.height;
                                clicked => {
                                    root.tree-menu-open = false;
                                    root.editor-menu-open = !root.editor-menu-open;
                                }
                                pointer-event(event) => {
                                    if event.kind == PointerEventKind.up && event.button == PointerEventButton.right {
                                        root.tree-menu-open = false;
                                        root.editor-menu-open = true;
                                    }
                                }
                            }
                        }
                        if root.editor-menu-open : Rectangle {
                            x: parent.width - 268px;
                            y: 34px;
                            width: 260px;
                            height: 365px;
                            background: #ffffff;
                            border-color: #64748b;
                            border-width: 1px;
                            VerticalLayout {
                                padding: 4px;
                                spacing: 1px;
                                ContextAction { label: "Kopieren"; activated => { root.editor-menu-open = false; editor.copy(); } }
                                ContextAction { label: "Ausschneiden"; activated => { root.editor-menu-open = false; editor.cut(); } }
                                ContextAction { label: "Einfügen"; activated => { root.editor-menu-open = false; editor.paste(); } }
                                ContextAction { label: "Alles markieren"; activated => { root.editor-menu-open = false; editor.select-all(); } }
                                ContextSeparator { }
                                ContextAction { label: "Bild einfügen"; activated => { root.editor-menu-open = false; root.insert-image(); } }
                                ContextAction { label: "Datum einfügen"; activated => { root.editor-menu-open = false; root.append-date(); } }
                                ContextAction { label: "Aufzählungszeichen einfügen"; activated => { root.editor-menu-open = false; root.append-bullet(); } }
                                ContextAction { label: "Löschen"; activated => { root.editor-menu-open = false; editor.cut(); } }
                                ContextSeparator { }
                                ContextAction { label: "Suchen"; activated => { root.editor-menu-open = false; root.search-next(root.search-text); } }
                                ContextAction { label: "Alle Treffer"; activated => { root.editor-menu-open = false; root.search-all(root.search-text); } }
                                ContextAction { label: "Ersetzen"; activated => { root.editor-menu-open = false; root.replace-text(root.search-text); } }
                                ContextAction { label: "Roh-RTF/Text umschalten"; activated => { root.editor-menu-open = false; root.toggle-raw-rtf(); } }
                                ContextAction { label: "Schließen"; activated => { root.editor-menu-open = false; } }
                            }
                        }
                    }
                    Rectangle {
                        height: 28px;
                        background: #fbfbfb;
                        border-color: #eeeeee;
                        border-width: 1px;
                        Text {
                            x: 6px;
                            width: parent.width - 12px;
                            height: parent.height;
                            text: root.meta-text;
                            vertical-alignment: center;
                            overflow: elide;
                        }
                    }
                }
            }
        }

        Rectangle {
            height: 30px;
            background: #f6f6f6;
            border-color: #dadada;
            border-width: 1px;
            Text {
                x: 8px;
                width: parent.width - 16px;
                height: parent.height;
                text: root.status-text;
                vertical-alignment: center;
                overflow: elide;
            }
        }
    }
}
